# ============================================
# 热点哨兵 - 环境变量配置
# ============================================

# 服务器端口
PORT=3000

# ============================================
# 本地AI模型配置 (Ollama)
# ============================================
# 是否使用本地AI模型 (true: 使用本地Ollama, false: 使用云端API)
USE_LOCAL_AI=true

# Ollama服务地址
OLLAMA_BASE_URL=http://localhost:11434

# 默认本地AI模型
# gemma3:4b - 快速响应模型
# qwen3.5:4b - 深度推理模型
OLLAMA_DEFAULT_MODEL=gemma3:4b
